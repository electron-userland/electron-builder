exports[`snap heavy > snap full (core18 armhf) 1`] = `
{
  "apps": {
    "se-wo-template": {
      "command": "command.sh",
      "environment": {
        "DISABLE_WAYLAND": "1",
        "LD_LIBRARY_PATH": "$SNAP_LIBRARY_PATH:$SNAP/lib:$SNAP/usr/lib:$SNAP/lib/arm-linux-gnueabihf:$SNAP/usr/lib/arm-linux-gnueabihf:$LD_LIBRARY_PATH:$SNAP/lib:$SNAP/usr/lib:$SNAP/lib/arm-linux-gnueabihf:$SNAP/usr/lib/arm-linux-gnueabihf",
        "PATH": "$SNAP/usr/sbin:$SNAP/usr/bin:$SNAP/sbin:$SNAP/bin:$PATH",
        "SNAP_DESKTOP_RUNTIME": "$SNAP/gnome-platform",
      },
      "plugs": [
        "desktop",
        "desktop-legacy",
        "home",
        "x11",
        "wayland",
        "unity7",
        "browser-support",
        "network",
        "gsettings",
        "audio-playback",
        "pulseaudio",
        "opengl",
      ],
    },
  },
  "base": "core18",
  "confinement": "strict",
  "description": "Test Application (test quite “ #378)",
  "grade": "stable",
  "name": "se-wo-template",
  "platforms": [
    "armhf",
  ],
  "plugs": {
    "gnome-3-28-1804": {
      "default-provider": "gnome-3-28-1804",
      "interface": "content",
      "target": "$SNAP/gnome-platform",
    },
    "gtk-3-themes": {
      "default-provider": "gtk-common-themes",
      "interface": "content",
      "target": "$SNAP/data-dir/themes",
    },
    "icon-themes": {
      "default-provider": "gtk-common-themes",
      "interface": "content",
      "target": "$SNAP/data-dir/icons",
    },
    "sound-themes": {
      "default-provider": "gtk-common-themes",
      "interface": "content",
      "target": "$SNAP/data-dir/sounds",
    },
  },
  "summary": "Snap Electron App (full build)",
  "title": "Snap Electron App (full build)",
  "version": "1.1.0",
}
`;

