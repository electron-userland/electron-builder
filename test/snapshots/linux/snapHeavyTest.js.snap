exports[`snap core24 native > core24 build + install + launch 1`] = `
{
  "apps": {
    "se-wo-template": {
      "command": "app/se-wo-template",
      "desktop": "meta/gui/se-wo-template.desktop",
      "plugs": [
        "desktop",
        "desktop-legacy",
        "home",
        "x11",
        "wayland",
        "unity7",
        "network",
        "gsettings",
        "audio-playback",
        "pulseaudio",
        "opengl",
        "browser-support",
      ],
    },
  },
  "base": "core24",
  "confinement": "strict",
  "description": "Test Application (test quite “ #378)",
  "environment": {
    "TMPDIR": "$XDG_RUNTIME_DIR",
  },
  "grade": "stable",
  "icon": "snap/gui/se-wo-template.png",
  "name": "se-wo-template",
  "parts": {
    "se-wo-template": {
      "organize": {
        "LICENSE.electron.txt": "app/LICENSE.electron.txt",
        "LICENSES.chromium.html": "app/LICENSES.chromium.html",
        "chrome-sandbox": "app/chrome-sandbox",
        "chrome_100_percent.pak": "app/chrome_100_percent.pak",
        "chrome_200_percent.pak": "app/chrome_200_percent.pak",
        "chrome_crashpad_handler": "app/chrome_crashpad_handler",
        "icudtl.dat": "app/icudtl.dat",
        "libEGL.so": "app/libEGL.so",
        "libGLESv2.so": "app/libGLESv2.so",
        "libffmpeg.so": "app/libffmpeg.so",
        "libvk_swiftshader.so": "app/libvk_swiftshader.so",
        "libvulkan.so.1": "app/libvulkan.so.1",
        "locales": "app/locales",
        "resources": "app/resources",
        "resources.pak": "app/resources.pak",
        "se-wo-template": "app/se-wo-template",
        "snapshot_blob.bin": "app/snapshot_blob.bin",
        "v8_context_snapshot.bin": "app/v8_context_snapshot.bin",
        "vk_swiftshader_icd.json": "app/vk_swiftshader_icd.json",
      },
      "plugin": "dump",
    },
  },
  "plugs": {
    "browser-support": {
      "allow-sandbox": true,
      "interface": "browser-support",
    },
  },
  "summary": "Snap Electron App",
  "title": "Snap Electron App",
  "version": "1.1.0",
}
`;

